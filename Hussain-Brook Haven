local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

local Window = WindUI:CreateWindow({
   Title = "Hussein Hub V1",
   SubTitle = "Brookhaven RP (2026)",
   Author = "by hussain_90_1",
   Size = UDim2.fromOffset(580, 500),
   Transparent = true
})

-- وظيفة جلب أسماء اللاعبين
local function getPlayerNames()
   local names = {}
   for _, p in pairs(game.Players:GetPlayers()) do
      if p ~= game.Players.LocalPlayer then 
         table.insert(names, p.Name) 
      end
   end
   return names
end

----------------------------------------------------
-- [1] قسم الرئيسية والأسماء الملونة
----------------------------------------------------
local TabHome = Window:Tab({ Title = "الرئيسية (RGB)", Icon = "rbxassetid://4483362458" })

TabHome:Section({ Title = "🌈 تلوين تلقائي (محاكاة لوحة الألوان)" })

local autoColorEnabled = false
TabHome:Toggle({
   Title = "تفعيل التلوين المتغير تلقائياً (RGB)",
   Value = false,
   Callback = function(state)
      autoColorEnabled = state
      if autoColorEnabled then
         WindUI:Notify({ Title = "Color Picker", Content = "تم تشغيل محاكاة لوحة الألوان بنجاح!", Duration = 3 })
         task.spawn(function()
            local hue = 0
            while autoColorEnabled do
               hue = hue + 0.05
               if hue > 1 then hue = 0 end
               local color = Color3.fromHSV(hue, 1, 1)
               pcall(function()
                  game:GetService("ReplicatedStorage").UpdateColor:FireServer(color)
                  local hexColor = string.format("#%02X%02X%02X", color.R*255, color.G*255, color.B*255)
                  game:GetService("ReplicatedStorage").UpdateName:FireServer("<font color='"..hexColor.."'>حسين</font>")
                  game:GetService("ReplicatedStorage").UpdateBio:FireServer("<font color='"..hexColor.."'>Hussein Hub V1</font>")
               end)
               task.wait(0.3)
            end
         end)
      end
   end
})

----------------------------------------------------
-- [2] قسم اختراق الجدران والمضادات (الجلد والحماية)
----------------------------------------------------
local TabExploits = Window:Tab({ Title = "الحماية والاختراق", Icon = "rbxassetid://4483362458" })

TabExploits:Section({ Title = "🔓 ميزة اختراق الجدران" })

local noclipEnabled = false
local noclipConnection
TabExploits:Toggle({
   Title = "تفعيل اختراق الجدران المستمر (NoClip)",
   Value = false,
   Callback = function(state)
      noclipEnabled = state
      if noclipEnabled then
         WindUI:Notify({ Title = "NoClip", Content = "تم تفعيل اختراق الجدران بنجاح!", Duration = 3 })
         noclipConnection = game:GetService("RunService").Stepped:Connect(function()
            if noclipEnabled and game.Players.LocalPlayer.Character then
               for _, part in pairs(game.Players.LocalPlayer.Character:GetChildren()) do
                  if part:IsA("BasePart") then part.CanCollide = false end
               end
            end
         end)
      else
         if noclipConnection then noclipConnection:Disconnect() end
         WindUI:Notify({ Title = "NoClip", Content = "تم إيقاف اختراق الجدران.", Duration = 3 })
      end
   end
})

TabExploits:Section({ Title = "🛡️ مضادات الطيران والكنب والسفن" })

local antiFlingEnabled = false
TabExploits:Toggle({
   Title = "مضاد الطيران والفلنق (سفينة، كنبة، أغراض طائرة)",
   Value = false,
   Callback = function(state)
      antiFlingEnabled = state
      if antiFlingEnabled then
         WindUI:Notify({ Title = "Anti-Fling", Content = "حماية الطيران الإجباري تعمل الآن!", Duration = 3 })
         task.spawn(function()
            while antiFlingEnabled do
               local char = game.Players.LocalPlayer.Character
               local hrp = char and char:FindFirstChild("HumanoidRootPart")
               local hum = char and char:FindFirstChildOfClass("Humanoid")
               
               if hrp and hum then
                  if hrp.Velocity.Magnitude > 70 or hrp.RotVelocity.Magnitude > 70 then
                     hrp.Velocity = Vector3.new(0, 0, 0)
                     hrp.RotVelocity = Vector3.new(0, 0, 0)
                  end
                  if hum.SeatPart then
                     hum.Sit = false
                     hrp.CFrame = hrp.CFrame + Vector3.new(0, 3, 0)
                  end
               end
               task.wait(0.1)
            end
         end)
      end
   end
})

local antiStuckEnabled = false
TabExploits:Toggle({
   Title = "مضاد اللصق والتعليق في الأرض (Anti-Anchor)",
   Value = false,
   Callback = function(state)
      antiStuckEnabled = state
      if antiStuckEnabled then
         task.spawn(function()
            while antiStuckEnabled do
               local char = game.Players.LocalPlayer.Character
               if char then
                  for _, part in pairs(char:GetChildren()) do
                     if part:IsA("BasePart") and part.Anchored then part.Anchored = false end
                  end
               end
               task.wait(0.2)
            end
         end)
      end
   end
})

