-- وظيفة جلب أسماء اللاعبين من السيرفر بشكل حيوي
local function getPlayerNames()
   local names = {}
   for _, p in pairs(game.Players:GetPlayers()) do
      if p ~= game.Players.LocalPlayer then 
         table.insert(names, p.Name) 
      end
   end
   return names
end

