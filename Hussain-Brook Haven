TabAR:Section({ Title = "تعديلات وتعديل سرعة السيارات" })
TabAR:Button({
   Title = "⚡ جعل سرعة سيارتك الحالية 200 (حقيقي)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      local humanoid = char and char:FindFirstChildOfClass("Humanoid")
      if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
         local seat = humanoid.SeatPart
         seat.MaxSpeed = 200
         seat.Torque = 15000
         if seat:FindFirstChild("VehicleEngine") then
            seat.VehicleEngine.MaxSpeed = 200
         end
         WindUI:Notify({ Title = "Speed Set!", Content = "تم تعديل سرعة السيارة الحالية إلى 200 حقيقية!", Duration = 3 })
      else
         WindUI:Notify({ Title = "تنبيه!", Content = "يجب أن تكون راكباً داخل مقعد السائق في السيارة أولاً!", Duration = 4 })
      end
   end
})

TabAR:Button({
   Title = "Hijack Closest Car (ركوب وسرقة أقرب سيارة فارغة)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      if char and char:FindFirstChild("HumanoidRootPart") then
         local targetSeat = nil
         local distance = math.huge
         for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("VehicleSeat") and obj.Occupant == nil then
               local d = (obj.Position - char.HumanoidRootPart.Position).Magnitude
               if d < distance then 
                  distance = d
                  targetSeat = obj 
               end
            end
         end
         if targetSeat then
            char.HumanoidRootPart.CFrame = targetSeat.CFrame + Vector3.new(0, 2, 0)
            task.wait(0.2)
            targetSeat:Sit(char:FindFirstChildOfClass("Humanoid"))
         end
      end
   end
})

TabAR:Section({ Title = "أدوات مراقبة السيرفر" })
local DropdownAR = TabAR:Dropdown({
   Title = "اختر لاعب لمراقبته",
   Values = getPlayerNames(),
   Callback = function(Option)
      if Option and Option ~= "" then
         local target = game.Players:FindFirstChild(Option)
         if target and target.Character and target.Character:FindFirstChildOfClass("Humanoid") then
            workspace.CurrentCamera.CameraSubject = target.Character:FindFirstChildOfClass("Humanoid")
         end
      end
   end
})

TabAR:Button({
   Title = "تحديث قائمة اللاعبين",
   Callback = function()
      DropdownAR:Refresh(getPlayerNames())
   end
})

TabAR:Button({
