})

TabPlayer:Section({ Title = "👁️ مراقبة السيرفر واللاعبين" })
local DropdownAR = TabPlayer:Dropdown({
   Title = "اختر لاعب لمراقبته عن بعد",
   Values = getPlayerNames(),
