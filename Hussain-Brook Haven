-- [5] قسم نظام التذكير الذكي
----------------------------------------------------
local TabReminder = Window:Tab({ Title = "نظام ذكرني", Icon = "rbxassetid://4483362458" })

local reminderText = "حان الوقت!"
local reminderTime = 10

TabReminder:Input({
   Title = "اكتب الشيء الذي تريد تذكره",
   Placeholder = "مثال: سرقة البنك، ركوب السيارة...",
   Callback = function(text) reminderText = text end
})

TabReminder:Input({
   Title = "الوقت قبل التذكير (بالثواني)",
   Placeholder = "10",
   Callback = function(num) reminderTime = tonumber(num) or 10 end
})

TabReminder:Button({
   Title = "🔔 ابدأ مؤقت التذكير",
   Callback = function()
      WindUI:Notify({ Title = "تم ضبط التذكير!", Content = "سأقوم بتذكيرك بعد " .. tostring(reminderTime) .. " ثانية.", Duration = 4 })
      task.spawn(function()
         task.wait(reminderTime)
         WindUI:Notify({ Title = "🚨 تذكير هام من حسين! 🚨", Content = reminderText, Duration = 10 })
         local p = game.Players.LocalPlayer
         if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local sound = Instance.new("Sound", p.Character.HumanoidRootPart)
            sound.SoundId = "rbxassetid://9114223173"
            sound.Volume = 2
            sound:Play()
            task.wait(3)
            sound:Destroy()
         end
      end)
   end
})
