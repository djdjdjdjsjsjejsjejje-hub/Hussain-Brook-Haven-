-- تعديل قسم السيارات لفصل ميزة السرعة والمراجيح بشكل صحيح
PlayerAR:CreateSection("تعديلات وتعديل سرعة السيارات")

PlayerAR:CreateButton({
   Name = "⚡ جعل سرعة سيارتك الحالية 200 (حقيقي)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      local humanoid = char and char:FindFirstChildOfClass("Humanoid")
      -- التحقق من أنك راكب داخل سيارة حالياً ليقوم بتعديل سرعتها فوراً
      if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
         local seat = humanoid.SeatPart
         seat.MaxSpeed = 200
         seat.Torque = 15000
         if seat:FindFirstChild("VehicleEngine") then
            seat.VehicleEngine.MaxSpeed = 200
         end
         Rayfield:Notify({Title = "Speed Set!", Content = "تم تعديل سرعة السيارة الحالية إلى 200 حقيقية!", Duration = 3})
      else
         Rayfield:Notify({Title = "تنبيه!", Content = "يجب أن تكون راكباً داخل مقعد السائق في السيارة أولاً!", Duration = 4})
      end
   end,
})

PlayerAR:CreateButton({
   Name = "Hijack Closest Car (ركوب وسرقة أقرب سيارة فارغة)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      if char and char:FindFirstChild("HumanoidRootPart") then
         local targetSeat = nil
         local distance = math.huge
         for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("VehicleSeat") and obj.Occupant == nil then
               local d = (obj.Position - char.HumanoidRootPart.Position).Magnitude
               if d < distance then 
                  distance = d
                  targetSeat = obj 
               end
            end
         end
         if targetSeat then
            char.HumanoidRootPart.CFrame = targetSeat.CFrame + Vector3.new(0, 2, 0)
            task.wait(0.2)
            targetSeat:Sit(char:FindFirstChildOfClass("Humanoid"))
         end
      end
   end,
})

PlayerAR:CreateSection("أدوات مراقبة السيرفر")

