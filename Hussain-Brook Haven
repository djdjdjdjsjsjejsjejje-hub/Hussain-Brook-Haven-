      if Option and Option ~= "" then
         local target = game.Players:FindFirstChild(Option)
         if target and target.Character and target.Character:FindFirstChildOfClass("Humanoid") then
            workspace.CurrentCamera.CameraSubject = target.Character:FindFirstChildOfClass("Humanoid")
         end
      end
   end
})

TabPlayer:Button({ Title = "🔄 تحديث قائمة اللاعبين", Callback = function() DropdownAR:Refresh(getPlayerNames()) end })
TabPlayer:Button({ Title = "❌ إلغاء المراقبة والعودة لشخصيتك", Callback = function() workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid") end })

