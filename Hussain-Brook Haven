local TabVehicles = Window:Tab({ Title = "قسم السيارات", Icon = "rbxassetid://4483362458" })

TabVehicles:Section({ Title = "🚗 رسبون وتحكم بالمركبات" })

-- قائمة بأشهر سيارات بروك هافن
local carList = {"Tesla", "Ferrari", "Mustang", "Jeep", "Supra", "Lamborghini", "Ambulance", "Police Car"}
local selectedCar = "Tesla"

TabVehicles:Dropdown({
   Title = "اختر السيارة المراد رسبنتها",
   Values = carList,
   Callback = function(value) selectedCar = value end
})

TabVehicles:Button({
   Title = "🏎️ رسبون السيارة المختارة فوراً",
   Callback = function()
      pcall(function()
         -- ريموت رسبون السيارات الرسمي في بروك هافن
         game:GetService("ReplicatedStorage").SpawnVehicle:FireServer(selectedCar)
         WindUI:Notify({ Title = "Car Spawned", Content = "تم رسبنة سيارتك بنجاح! اركبها لتعديل السرعة.", Duration = 3 })
      end)
   end
})

TabVehicles:Section({ Title = "⚡ هكر السرعة الخارقة للسيارات" })

TabVehicles:Button({
   Title = "🚀 جعل سرعة سيارتك الحالية 200 (تعديل العزم الحقيقي)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      local humanoid = char and char:FindFirstChildOfClass("Humanoid")
      if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
         local seat = humanoid.SeatPart
         seat.MaxSpeed = 200
         seat.Torque = 30000 -- عزم جبار عشان ما تقطع السيارة بالتفحيط
         seat.TurnSpeed = 25 -- تحسين لفة السيارة على السرعات العالية
         WindUI:Notify({ Title = "Speed Hack Active", Content = "تم تعديل المحرك! سرعتك الآن 200 حصان حقيقي!", Duration = 4 })
      else
         WindUI:Notify({ Title = "تنبيه!", Content = "يجب أن تكون راكباً داخل مقعد السائق أولاً!", Duration = 4 })
      end
   end
})

TabVehicles:Button({
   Title = "🛑 تدمير وحذف سيارتك الحالية",
   Callback = function()
      pcall(function()
         game:GetService("ReplicatedStorage").RemoveVehicle:FireServer()
         WindUI:Notify({ Title = "Car Removed", Content = "تم حذف السيارة من الماب.", Duration = 2 })
      end)
   end
})

