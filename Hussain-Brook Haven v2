-- وظيفة جلب أسماء اللاعبين بشكل منظم وسريع
local function getPlayerNames()
   local names = {}
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer then 
         table.insert(names, p.Name) 
      end
   end
   return names
end

-- وظيفة جلب الوقت الحالي بتوقيت العراق (نظام 12 ساعة دقيق)
local function getIraqTime()
   local localTime = os.date("*t")
   local hour = localTime.hour
   local period = "AM"
   
   if hour >= 12 then
      period = "مساءً"
      if hour > 12 then hour = hour - 12 end
   else
      period = "صباحاً"
      if hour == 0 then hour = 12 end
   end
   
   return string.format("%02d:%02d:%02d %s", hour, localTime.min, localTime.sec, period)
end

-- وظيفة جلب التاريخ
local function getIraqDate()
   return os.date("%Y/%m/%d")
end

