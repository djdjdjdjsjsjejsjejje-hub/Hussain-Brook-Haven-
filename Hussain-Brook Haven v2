-- وظيفة جلب أسماء اللاعبين
local function getPlayerNames()
   local names = {}
   for _, p in pairs(game.Players:GetPlayers()) do
      if p ~= game.Players.LocalPlayer then 
         table.insert(names, p.Name) 
      end
   end
   return names
end

-- وظيفة جلب الوقت الحالي من جهازك العراقي مباشرة (نظام 12 ساعة مريح)
local function getIraqTime()
   local localTime = os.date("*t") -- يقرأ وقت جهازك في العراق فوراً بدون زيادة
   local hour = localTime.hour
   local period = "AM"
   
   if hour >= 12 then
      period = "مساءً"
      if hour > 12 then
         hour = hour - 12
      end
   else
      period = "صباحاً"
      if hour == 0 then
         hour = 12
      end
   end
   
   return string.format("%02d:%02d:%02d %s", hour, localTime.min, localTime.sec, period)
end

-- وظيفة جلب التاريخ من جهازك العراقي مباشرة
local function getIraqDate()
   return os.date("%Y/%m/%d") -- يقرأ تاريخ جهازك فوراً
end

