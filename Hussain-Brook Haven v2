local TabCopyOutfit = Window:Tab({ Title = "نسخ السكنات", Icon = "rbxassetid://4483362458" })

TabCopyOutfit:Section({ Title = " قلد وانسخ مظهر اللاعبين" })

local function copyPlayerOutfit(targetName)
   local targetPlayer = Players:FindFirstChild(targetName)
   
   if targetPlayer and targetPlayer.Character and LocalPlayer.Character then
      local localHumanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
      if localHumanoid then
         local success, outfitDescription = pcall(function()
            return Players:GetHumanoidDescriptionFromUserId(targetPlayer.UserId)
         end)
         
         if success and outfitDescription then
            localHumanoid:ApplyDescription(outfitDescription)
            WindUI:Notify({ Title = "Hussein Hub V2", Content = "تم نسخ وتطبيق سكن اللاعب بنجاح!", Duration = 4 })
         else
            WindUI:Notify({ Title = "خطأ!", Content = "فشل جلب بيانات المظهر الخاصة باللاعب!", Duration = 3 })
         end
      end
   else
      WindUI:Notify({ Title = "تنبيه!", Content = "الهدف غير موجود أو أن شخصيتك لم تكتمل بعد!", Duration = 3 })
   end
end

local DropdownOutfit = TabCopyOutfit:Dropdown({
   Title = "اختر لاعب من السيرفر لنسخ مظهرة",
   Values = getPlayerNames(),
   Callback = function(Option)
      if Option and Option ~= "" then copyPlayerOutfit(Option) end
   end
})

TabCopyOutfit:Button({ Title = " تحديث قائمة السكنات", Callback = function() DropdownOutfit:Refresh(getPlayerNames()) end })

TabCopyOutfit:Section({ Title = " نسخ السكن بالاسم اليدوي" })
local targetInputName = ""
TabCopyOutfit:Input({
   Title = "اكتب اسم اللاعب الكامل (Username)",
   Placeholder = "مثال: Hussain4646767",
   Callback = function(text) targetInputName = text end
})

TabCopyOutfit:Button({
   Title = " تطبيق المظهر المكتوب الآن",
   Callback = function()
      if targetInputName ~= "" then copyPlayerOutfit(targetInputName) else WindUI:Notify({ Title = "تنبيه!", Content = "يرجى إدخال اسم صحيح أولاً!", Duration = 3 }) end
   end
})

