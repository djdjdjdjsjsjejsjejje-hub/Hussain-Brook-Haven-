local TabCopyOutfit = Window:Tab({ Title = "نسخ السكنات", Icon = "rbxassetid://4483362458" })

TabCopyOutfit:Section({ Title = " قلد وانسخ سكنات اللاعبين" })

local function copyPlayerOutfit(targetName)
   local targetPlayer = game.Players:FindFirstChild(targetName)
   local localPlayer = game.Players.LocalPlayer
   
   if targetPlayer and targetPlayer.Character and localPlayer.Character then
      local localHumanoid = localPlayer.Character:FindFirstChildOfClass("Humanoid")
      
      if localHumanoid then
         local pcallSuccess, outfitDescription = pcall(function()
            return game.Players:GetHumanoidDescriptionFromUserId(targetPlayer.UserId)
         end)
         
         if pcallSuccess and outfitDescription then
            localHumanoid:ApplyDescription(outfitDescription)
            WindUI:Notify({ 
               Title = "Hussein Hub V2", 
               Content = "تم نسخ سكن اللاعب " .. targetName .. " بنجاح!", 
               Duration = 4 
            })
         else
            WindUI:Notify({ Title = "خطأ!", Content = "فشل جلب بيانات مظهر اللاعب!", Duration = 3 })
         end
      end
   else
      WindUI:Notify({ Title = "تنبيه!", Content = "اللاعب غير موجود أو شخصيتك غير جاهزة!", Duration = 3 })
   end
end

local DropdownOutfit = TabCopyOutfit:Dropdown({
   Title = "اختر لاعب من السيرفر لنسخ مظهرة",
   Values = getPlayerNames(),
   Callback = function(Option)
      if Option and Option ~= "" then
         copyPlayerOutfit(Option)
      end
   end
})

TabCopyOutfit:Button({ 
   Title = " تحديث قائمة اللاعبين لنسخ السكن", 
   Callback = function() 
      DropdownOutfit:Refresh(getPlayerNames()) 
   end 
})

TabCopyOutfit:Section({ Title = " نسخ السكن عن طريق الكتابة" })

local targetInputName = ""
TabCopyOutfit:Input({
   Title = "اكتب اسم اللاعب الكامل (Username)",
   Placeholder = "مثال: Hussain4646767",
   Callback = function(text) 
      targetInputName = text 
   end
})

TabCopyOutfit:Button({
