TabExploits:Section({ Title = "مضادات الطيران والتهنيج" })

local antiFlingEnabled = false
TabExploits:Toggle({
   Title = "مضاد الطيران والفلنق الحركي",
   Value = false,
   Callback = function(state)
      antiFlingEnabled = state
      if antiFlingEnabled then
         WindUI:Notify({ Title = "Anti-Fling", Content = "حماية الطيران الإجباري تعمل الآن بكفاءة!", Duration = 3 })
         task.spawn(function()
            while antiFlingEnabled do
               local char = LocalPlayer.Character
               local hrp = char and char:FindFirstChild("HumanoidRootPart")
               local hum = char and char:FindFirstChildOfClass("Humanoid")
               
               if hrp and hum then
                  -- تصفير العزم العشوائي الناتج عن الفلنق أو الكنب الطائر لمنع قذف اللاعب
                  if hrp.Velocity.Magnitude > 70 or hrp.RotVelocity.Magnitude > 70 then
                     hrp.Velocity = Vector3.zero
                     hrp.RotVelocity = Vector3.zero
                  end
                  if hum.SeatPart then
                     hum.Sit = false
                     hrp.CFrame = hrp.CFrame + Vector3.new(0, 3, 0)
                  end
               end
               task.wait(0.1)
            end
         end)
      end
   end
})

local antiStuckEnabled = false
TabExploits:Toggle({
   Title = "مضاد اللصق والتعليق (Anti-Anchor)",
   Value = false,
   Callback = function(state)
      antiStuckEnabled = state
      if antiStuckEnabled then
         task.spawn(function()
